# Agnic — one key for both LLM gateway and x402 service payments.
# OpenAI-compatible /v1/chat/completions; same model identifiers as OpenRouter.
# The associated wallet must be funded with USDC on Base (or Base Sepolia for testing).
AGNIC_API_KEY=agnic_tok_...

# Optional: override the default model used for discovery ranking / general LLM calls.
AI_MODEL=anthropic/claude-sonnet-4.6

# Optional: override the model used for final verdict synthesis (Opus is expensive — tune as needed).
SYNTHESIS_MODEL=anthropic/claude-opus-4.7

# Optional: pre-flight balance threshold (USDC) for /verify-agent.
# If the wallet's spendable balance is below this, the route aborts with 503.
AGNIC_BUDGET_MIN_USD=0.10

# Optional: per-call x402 budget headroom over a service's stored price, to
# absorb small upstream price drift without a hard payment_exceeds_max failure.
# Effective cap = min(price × buffer, $0.10 ceiling). Default 1.5.
# INVOKE_MAXVALUE_BUFFER=1.5

# Optional: restrict CORS to your frontend origin.
ALLOWED_ORIGIN=http://localhost:5173

# Optional: port (default 8000).
PORT=8000

# Optional: MCP HTTP bearer. This is now OPTIONAL — the /mcp route also accepts
# any valid self-serve API key (POST /request-key), validated against the DB. If
# BOTH this is unset AND DATABASE_URL is unset, /mcp returns 503 mcp_disabled
# (nothing could authorize a caller). Set this to keep an admin bypass token.
# MCP_SHARED_SECRET=

# Optional (frontend build env, NOT read by the backend): an issued key the web
# UI sends as a Bearer on verify/discover requests so its paid runs are
# attributed in service_observations. NOT a secret (it ships in the bundle) —
# attribution + revocation only. Provision once: `curl -X POST <api>/request-key
# -d '{"label":"web-ui"}'`, then set VITE_WARDO_WEB_KEY in the web build env
# (e.g. Cloudflare Pages). Unset → web runs are anonymous (api_key_id NULL).
# VITE_WARDO_WEB_KEY=wardo_sk_...

# Optional: Postgres (Neon). Unset = the DB layer is a no-op and the default
# test suite runs fully offline. Both prod and local dev use the Neon *pooled*
# (-pooler) endpoint — same connection style everywhere (no Docker). Prod points
# at the `main` branch, local dev at a separate Neon *dev branch* for isolation.
#   DATABASE_URL=postgresql://USER:PASS@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require
# DATABASE_URL=

# Optional: post-deploy prod E2E smoke (`deno task smoke:prod`). All three must
# be set to run it; unset → the test is skipped and `deno task test` stays
# offline. It MAKES REAL x402 PAID CALLS (~$0.01-$0.05 USDC) against live prod
# and reads the prod DB to assert usage_events + api_key_id attribution landed.
#   RUN_PROD_E2E=1
#   PROD_BASE_URL=https://wallet-verifier.ward-o.deno.net   # default if unset
# DATABASE_URL below must point at the prod `production` branch (read-only is
# enough) for the assertion queries.
# RUN_PROD_E2E=

# Optional: vetter probation-probe phase (src/vetter/probe.ts). The vetter's
# twice-daily cron pays-and-invokes probation candidates against the wallet
# fixtures so they accrue the observations needed to be promoted (or blocked).
# SPENDS REAL USDC — off by default. Two guards bound it: a per-run spend ceiling
# (BUDGET) and a balance floor (MIN_BALANCE, skips the phase below a reserve).
# Max daily spend = 2 runs × BUDGET. Recommended to enable: BUDGET=0.25, plus a
# floor like MIN_BALANCE=5. Unset/0 = the phase is a no-op.
#   VETTER_PROBE_BUDGET_USDC=0.25       # per-run ceiling; 0/unset disables
#   VETTER_PROBE_MIN_BALANCE_USDC=5     # skip probing below this balance; 0=off
#   VETTER_PROBE_MAX_PRICE_USDC=0.10    # skip candidates dearer than this
#   VETTER_PROBE_FIXTURES=3             # fixtures probed per candidate per run
# VETTER_PROBE_BUDGET_USDC=

# Optional: Neon management API (powers the `neon` MCP server in .mcp.json).
# NEON_API_KEY is a *project-scoped* key — it can only reach the one project below
# and CANNOT list projects/orgs. Always pass NEON_PROJECT_ID as `projectId` on
# every mcp__neon__* call; the key cannot discover its own project id.
# NEON_API_KEY=napi_xxxxxxxx
# NEON_PROJECT_ID=super-grass-68246474
