# Agnic — one key for both LLM gateway and x402 service payments.
# OpenAI-compatible /v1/chat/completions; same model identifiers as OpenRouter.
AGNIC_API_KEY=agnic_tok_...

# Bazaar x402-enabled endpoints (required for agent loop to make real calls)
BAZAAR_OFAC_URL=           # e.g. https://api.bazaar.network/ofac/check
BAZAAR_LABELS_URL=         # e.g. https://api.bazaar.network/labels
BAZAAR_WEB_SEARCH_URL=     # e.g. https://api.bazaar.network/web-search
BAZAAR_CONTRACT_URL=       # e.g. https://api.bazaar.network/contract
ETHERSCAN_X402_URL=        # e.g. https://api.etherscan.io/api (if x402-gated)

# Optional: override the default model used for synthesis
AI_MODEL=anthropic/claude-sonnet-4.6

# Optional: restrict CORS to your frontend origin
ALLOWED_ORIGIN=http://localhost:5173

# Optional: port (default 8000)
PORT=8000
