{
  "exclude": [
    ".claude/worktrees/",
    "web/node_modules/",
    "web/dist/"
  ],
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env --allow-read --allow-write --env-file=.env src/main.ts",
    "start": "deno run --allow-net --allow-env --allow-read --allow-write --env-file=.env src/main.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check src/**/*.ts",
    "test": "deno test --allow-net --allow-env --allow-read --allow-write --allow-sys",
    "test:unit": "deno test --allow-net --allow-env --allow-read --allow-write --allow-sys",
    "test:e2e": "RUN_E2E=1 deno test --allow-net --allow-env --allow-read --allow-write --allow-sys",
    "mcp:stdio": "deno run --allow-net --allow-env --allow-read --allow-write --env-file=.env src/mcp/stdio.ts",
    "benchmark": "deno run --allow-net --allow-env --allow-read --allow-write --env-file=.env scripts/benchmark.ts",
    "cassette:record": "HEALTH_TRACKING=false deno run --allow-net --allow-env --allow-read --allow-write --env-file=.env scripts/record-cassettes.ts",
    "test:replay": "HEALTH_TRACKING=false deno test --allow-read --allow-env tests/replay_test.ts"
  },
  "imports": {
    "hono": "jsr:@hono/hono@^4.7.11",
    "hono/cors": "jsr:@hono/hono@^4.7.11/cors",
    "hono/streaming": "jsr:@hono/hono@^4.7.11/streaming",
    "hono/zod-validator": "jsr:@hono/zod-validator@^0.7.0",
    "zod": "npm:zod@^4.4.3",
    "viem": "npm:viem@^2",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.5",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@modelcontextprotocol/sdk/": "npm:/@modelcontextprotocol/sdk@^1.29.0/"
  },
  "lint": {
    "include": ["src/"],
    "rules": {
      "exclude": ["no-explicit-any"]
    }
  },
  "fmt": {
    "include": ["src/"],
    "indentWidth": 2,
    "singleQuote": false
  }
}
