{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env src/main.ts",
    "start": "deno run --allow-net --allow-env src/main.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check src/main.ts",
    "test": "deno test --allow-net --allow-env"
  },
  "imports": {
    "hono": "jsr:@hono/hono@^4.7.11",
    "hono/cors": "jsr:@hono/hono@^4.7.11/cors",
    "hono/zod-validator": "jsr:@hono/zod-validator@^0.7.0",
    "zod": "npm:zod@^4.4.3",
    "ai": "npm:ai@^4.3.16",
    "@openrouter/ai-sdk-provider": "npm:@openrouter/ai-sdk-provider@^0.4.5",
    "@std/assert": "jsr:@std/assert@^1.0.19"
  },
  "lint": {
    "rules": {
      "exclude": ["no-explicit-any"]
    }
  },
  "fmt": {
    "indentWidth": 2,
    "singleQuote": false
  }
}
